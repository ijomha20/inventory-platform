# ================================================================
# CARFAX AUTOMATION - CONFIGURATION
# Copy this file to .env and fill in your values.
# ================================================================

# The Web App URL from your Apps Script deployment
# (see README.txt Step 2 for how to get this)
WEBAPP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Which browser to use: chrome or msedge
# Use msedge if Chrome is already open (e.g. you are using Chrome for something else)
# Microsoft Edge is pre-installed on all Windows 10/11 computers.
BROWSER=chrome

# Path to your browser profile directory.
# Leave blank to auto-detect for your OS.
# Chrome Mac:     /Users/YOURNAME/Library/Application Support/Google/Chrome
# Chrome Windows: C:\Users\YOURNAME\AppData\Local\Google\Chrome\User Data
# Edge Windows:   C:\Users\YOURNAME\AppData\Local\Microsoft\Edge\User Data
CHROME_PROFILE_PATH=

# Which browser profile folder to use (usually "Default")
CHROME_PROFILE=Default

# Pause between each VIN search in milliseconds (default 3000 = 3 seconds)
DELAY_BETWEEN_VINS=3000
