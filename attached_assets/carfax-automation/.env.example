# ================================================================
# CARFAX AUTOMATION - CONFIGURATION
# Copy this file to .env and fill in your values.
# Never share your .env file with anyone.
# ================================================================

# Your Google Spreadsheet ID
# Found in the URL: docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# The name of the tab that holds your inventory
SHEET_NAME=My List

# Path to your Chrome user profile directory
# Leave blank to use the default detected path for your OS.
# Mac default:     /Users/YOURNAME/Library/Application Support/Google/Chrome
# Windows default: C:\Users\YOURNAME\AppData\Local\Google\Chrome\User Data
CHROME_PROFILE_PATH=

# Which Chrome profile folder to use (usually "Default", but check your Chrome profiles)
CHROME_PROFILE=Default

# How long to pause between VIN searches in milliseconds (default: 3000 = 3 seconds)
# Increase this if Carfax seems to be rate-limiting you.
DELAY_BETWEEN_VINS=3000
