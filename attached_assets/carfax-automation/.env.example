# ================================================================
# CARFAX AUTOMATION - CONFIGURATION
# Copy this file to .env and fill in your values.
# ================================================================

# The Web App URL from your Apps Script deployment
WEBAPP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Optional: your Carfax login credentials.
# If left blank, the browser will open and pause so you can
# log in manually on the first run. After that, the session
# is saved and you will not need to log in again.
CARFAX_EMAIL=
CARFAX_PASSWORD=

# Pause between each VIN search in milliseconds (default 3000 = 3 seconds)
DELAY_BETWEEN_VINS=3000
